- (ServiceToken.possible_scopes - ["group_health", "census_evaluations"]).each do |scope|
  = f.boolean_field(scope.to_sym, caption: model_class.human_attribute_name(scope.to_sym))
- if parent.class == Group::Bund
  = f.boolean_field(:group_health, caption: model_class.human_attribute_name(:group_health))
  = f.boolean_field(:census_evaluations, caption: model_class.human_attribute_name(:census_evaluations))
